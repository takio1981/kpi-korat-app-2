# --- Server Config ---
PORT=8809

# --- JWT Config (จำเป็นต้องตั้งค่า — server จะไม่เริ่มถ้าไม่มี JWT_SECRET) ---
JWT_SECRET=change_me_to_random_string_at_least_32_chars
JWT_EXPIRES_IN=8h

# --- CORS Config ---
# ไม่ต้องตั้งค่านี้ก็ได้ (ค่า default = อนุญาตทุก origin เพราะใช้ Nginx Proxy)
# ถ้าต้องการจำกัดเฉพาะบาง Domain ให้ระบุ เช่น:
# CORS_ALLOWED_ORIGINS=http://localhost:8808,http://192.168.5.124:8808

# --- Database Config ---
# สำหรับ Developer (Docker Desktop Windows/Mac): ใช้ host.docker.internal
# สำหรับ Production (Linux): ใส่ IP ของเครื่อง Database Server จริง (เช่น 172.17.0.1 หรือ 192.168.1.x)
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=korat_kpi
# DB_POOL_LIMIT=50
