# --- Server Config ---
PORT=8809
# --- CORS Config ---
# กำหนด Domains ที่จะอนุญาตให้เรียก API ได้ (คั่นด้วยลูกน้ำ ,)
# ตัวอย่าง: http://localhost:8808,http://192.168.5.124:8808
CORS_ALLOWED_ORIGINS=http://localhost:8808,http://192.168.123.162:8808

# --- Database Config ---
# สำหรับ Developer (Docker Desktop Windows/Mac): ใช้ host.docker.internal
# สำหรับ Production: ใส่ IP ของเครื่อง Database Server จริง (เช่น 192.168.1.x)
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=korat_kpi
